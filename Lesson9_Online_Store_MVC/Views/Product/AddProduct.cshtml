@model Product

<form asp-controller="Product" asp-action="AddProduct" method="post" class="card-body">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ProductCount"></label>
        <input asp-for="ProductCount" type="number" class="form-control" />
        <span asp-validation-for="ProductCount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId">Category</label>
        <select asp-for="CategoryId" class="form-control">
            <option value="0">Select category</option>
            @foreach (var c in (IEnumerable<Category>)ViewBag.Categories)
            {
                <option value="@c.Id">@c.Name @c.Id</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>


        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="card-footer">
        <button type="submit" class="btn btn-primary">Submit</button>
    </div>
</form>
